@page "/"
@inject HttpClient Http
@using System.Timers

<PageTitle>Dashboard — TiendaApp</PageTitle>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
    <div>
        <h2 style="margin:0;">📊 Dashboard</h2>
        <p style="color:#888; margin:.3rem 0 0; font-size:.9rem;">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
    </div>
    <button @onclick="Recargar" style="padding:.5rem 1rem; background:#f5f5f5; border:1px solid #ddd; border-radius:8px; cursor:pointer;">
        🔄 Actualizar
    </button>
</div>

@if (cargando)
{
    <p style="text-align:center; color:#888; padding:3rem;">Cargando datos del día...</p>
}
else
{
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; margin-bottom:2rem;">
        <div style="background:linear-gradient(135deg,#2e7d32,#43a047); color:white; border-radius:12px; padding:1.2rem;">
            <div style="font-size:.85rem; opacity:.85;">Ventas del día</div>
            <div style="font-size:2rem; font-weight:bold;">S/ @resumen.TotalVentas.ToString("N2")</div>
            <div style="font-size:.8rem; opacity:.75;">@resumen.NumeroVentas venta(s) realizadas</div>
        </div>
        <div style="background:linear-gradient(135deg,#1565c0,#1e88e5); color:white; border-radius:12px; padding:1.2rem;">
            <div style="font-size:.85rem; opacity:.85;">Efectivo</div>
            <div style="font-size:2rem; font-weight:bold;">S/ @resumen.TotalEfectivo.ToString("N2")</div>
            <div style="font-size:.8rem; opacity:.75;">Cobros en efectivo</div>
        </div>
        <div style="background:linear-gradient(135deg,#6a1b9a,#8e24aa); color:white; border-radius:12px; padding:1.2rem;">
            <div style="font-size:.85rem; opacity:.85;">Yape / Tarjeta</div>
            <div style="font-size:2rem; font-weight:bold;">S/ @resumen.TotalDigital.ToString("N2")</div>
            <div style="font-size:.8rem; opacity:.75;">Pagos digitales</div>
        </div>
        <div style="background:linear-gradient(135deg,#e65100,#fb8c00); color:white; border-radius:12px; padding:1.2rem;">
            <div style="font-size:.85rem; opacity:.85;">Ticket promedio</div>
            <div style="font-size:2rem; font-weight:bold;">S/ @(resumen.NumeroVentas > 0 ? (resumen.TotalVentas / resumen.NumeroVentas).ToString("N2") : "0.00")</div>
            <div style="font-size:.8rem; opacity:.75;">Por venta</div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns:2fr 1fr; gap:1rem;">

        <div style="background:#fafafa; border:1px solid #eee; border-radius:12px; padding:1.2rem;">
            <h3 style="margin:0 0 1rem;">Últimas ventas del día</h3>
            @if (!resumen.UltimasVentas.Any())
            {
                <p style="color:#aaa; text-align:center; padding:2rem;">Sin ventas aún hoy.<br/>Ve al <a href="/pos" style="color:#2e7d32;">Punto de Venta</a> para registrar.</p>
            }
            else
            {
                <table style="width:100%; border-collapse:collapse; font-size:.9rem;">
                    <thead>
                        <tr style="color:#888; border-bottom:1px solid #eee;">
                            <th style="padding:.4rem; text-align:left;">#</th>
                            <th style="padding:.4rem; text-align:left;">Hora</th>
                            <th style="padding:.4rem; text-align:left;">Cliente</th>
                            <th style="padding:.4rem; text-align:left;">Pago</th>
                            <th style="padding:.4rem; text-align:right;">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in resumen.UltimasVentas)
                        {
                            <tr style="border-bottom:1px solid #f5f5f5;">
                                <td style="padding:.5rem; color:#aaa;">#@v.Id</td>
                                <td style="padding:.5rem;">@v.Fecha.ToString("HH:mm")</td>
                                <td style="padding:.5rem;">@v.ClienteNombre</td>
                                <td style="padding:.5rem;">
                                    <span style="background:#e8eaf6; color:#3949ab; padding:2px 8px; border-radius:10px; font-size:.8rem;">@v.MetodoPago</span>
                                </td>
                                <td style="padding:.5rem; text-align:right; font-weight:bold; color:#2e7d32;">S/ @v.Total.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div style="display:flex; flex-direction:column; gap:1rem;">
            <div style="background:#fafafa; border:1px solid #eee; border-radius:12px; padding:1.2rem;">
                <h3 style="margin:0 0 1rem;">⚡ Accesos rápidos</h3>
                <a href="/pos" style="display:block; padding:.8rem; background:#2e7d32; color:white; border-radius:8px; text-decoration:none; text-align:center; margin-bottom:.6rem; font-weight:bold;">
                    🛒 Nueva venta
                </a>
                <a href="/ventas" style="display:block; padding:.8rem; background:#1565c0; color:white; border-radius:8px; text-decoration:none; text-align:center; margin-bottom:.6rem; font-weight:bold;">
                    📋 Ver ventas
                </a>
                <a href="/productos" style="display:block; padding:.8rem; background:#6a1b9a; color:white; border-radius:8px; text-decoration:none; text-align:center; font-weight:bold;">
                    📦 Productos
                </a>
            </div>

            <div style="background:#fafafa; border:1px solid #eee; border-radius:12px; padding:1.2rem;">
                <h3 style="margin:0 0 .8rem;">📈 Resumen</h3>
                <div style="display:flex; justify-content:space-between; padding:.4rem 0; border-bottom:1px solid #f0f0f0; font-size:.9rem;">
                    <span style="color:#555;">Total del día</span>
                    <strong>S/ @resumen.TotalVentas.ToString("N2")</strong>
                </div>
                <div style="display:flex; justify-content:space-between; padding:.4rem 0; border-bottom:1px solid #f0f0f0; font-size:.9rem;">
                    <span style="color:#555;">Número de ventas</span>
                    <strong>@resumen.NumeroVentas</strong>
                </div>
                <div style="display:flex; justify-content:space-between; padding:.4rem 0; border-bottom:1px solid #f0f0f0; font-size:.9rem;">
                    <span style="color:#555;">Efectivo</span>
                    <strong style="color:#1565c0;">S/ @resumen.TotalEfectivo.ToString("N2")</strong>
                </div>
                <div style="display:flex; justify-content:space-between; padding:.4rem 0; font-size:.9rem;">
                    <span style="color:#555;">Digital</span>
                    <strong style="color:#6a1b9a;">S/ @resumen.TotalDigital.ToString("N2")</strong>
                </div>
            </div>
        </div>
    </div>
}

@code {
    string apiUrl = "http://localhost:5102";
    bool cargando = true;
    ResumenDto resumen = new();

    protected override async Task OnInitializedAsync() => await Recargar();

    async Task Recargar()
    {
        cargando = true;
        try
        {
            resumen = await Http.GetFromJsonAsync<ResumenDto>($"{apiUrl}/api/Ventas/resumen") ?? new();
        }
        catch { resumen = new(); }
        cargando = false;
    }

    class ResumenDto
    {
        public decimal TotalVentas { get; set; }
        public int NumeroVentas { get; set; }
        public decimal TotalEfectivo { get; set; }
        public decimal TotalDigital { get; set; }
        public List<VentaDto> UltimasVentas { get; set; } = new();
    }

    class VentaDto
    {
        public int Id { get; set; }
        public DateTime Fecha { get; set; }
        public string ClienteNombre { get; set; } = "";
        public string MetodoPago { get; set; } = "";
        public decimal Total { get; set; }
    }
}