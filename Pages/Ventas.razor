@page "/ventas"
@inject HttpClient Http

<PageTitle>Ventas — TiendaApp</PageTitle>

<h2>📋 Historial de ventas</h2>

@if (cargando)
{
    <p style="text-align:center; color:#888; padding:2rem;">Cargando ventas...</p>
}
else
{
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; margin-bottom:2rem;">
        <div style="background:linear-gradient(135deg,#2e7d32,#43a047); color:white; border-radius:12px; padding:1.2rem;">
            <div style="font-size:.85rem; opacity:.85;">Total hoy</div>
            <div style="font-size:1.8rem; font-weight:bold;">S/ @resumen.TotalVentas.ToString("N2")</div>
            <div style="font-size:.8rem; opacity:.75;">@resumen.NumeroVentas ventas</div>
        </div>
        <div style="background:linear-gradient(135deg,#1565c0,#1e88e5); color:white; border-radius:12px; padding:1.2rem;">
            <div style="font-size:.85rem; opacity:.85;">Efectivo</div>
            <div style="font-size:1.8rem; font-weight:bold;">S/ @resumen.TotalEfectivo.ToString("N2")</div>
        </div>
        <div style="background:linear-gradient(135deg,#6a1b9a,#8e24aa); color:white; border-radius:12px; padding:1.2rem;">
            <div style="font-size:.85rem; opacity:.85;">Digital</div>
            <div style="font-size:1.8rem; font-weight:bold;">S/ @resumen.TotalDigital.ToString("N2")</div>
        </div>
    </div>

    <table style="width:100%; border-collapse:collapse; font-size:.9rem;">
        <thead>
            <tr style="background:#f5f5f5; text-align:left;">
                <th style="padding:.6rem;">#</th>
                <th style="padding:.6rem;">Hora</th>
                <th style="padding:.6rem;">Cliente</th>
                <th style="padding:.6rem;">Método de pago</th>
                <th style="padding:.6rem; text-align:right;">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in resumen.UltimasVentas)
            {
                <tr style="border-bottom:1px solid #f0f0f0;">
                    <td style="padding:.6rem; color:#888;">#@v.Id</td>
                    <td style="padding:.6rem;">@v.Fecha.ToString("HH:mm")</td>
                    <td style="padding:.6rem;">@v.ClienteNombre</td>
                    <td style="padding:.6rem;">
                        <span style="background:#e8eaf6; color:#3949ab; padding:2px 8px; border-radius:10px; font-size:.8rem;">
                            @v.MetodoPago
                        </span>
                    </td>
                    <td style="padding:.6rem; text-align:right; font-weight:bold; color:#2e7d32;">
                        S/ @v.Total.ToString("F2")
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!resumen.UltimasVentas.Any())
    {
        <p style="text-align:center; color:#aaa; padding:2rem;">Sin ventas registradas hoy. Ve al Punto de Venta para registrar.</p>
    }
}

@code {
    string apiUrl = "http://localhost:5102";
    bool cargando = true;
    ResumenDto resumen = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            resumen = await Http.GetFromJsonAsync<ResumenDto>($"{apiUrl}/api/Ventas/resumen") ?? new();
        }
        catch { }
        cargando = false;
    }

    class ResumenDto
    {
        public decimal TotalVentas { get; set; }
        public int NumeroVentas { get; set; }
        public decimal TotalEfectivo { get; set; }
        public decimal TotalDigital { get; set; }
        public List<VentaDto> UltimasVentas { get; set; } = new();
    }

    class VentaDto
    {
        public int Id { get; set; }
        public DateTime Fecha { get; set; }
        public string ClienteNombre { get; set; } = "";
        public string MetodoPago { get; set; } = "";
        public decimal Total { get; set; }
    }
}