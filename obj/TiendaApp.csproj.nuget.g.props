  </ImportGroup>
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <PkgMicrosoft_NET_Sdk_WebAssembly_Pack Condition=" '$(PkgMicrosoft_NET_Sdk_WebAssembly_Pack)' == '' ">C:\Users\llocl\.nuget\packages\microsoft.net.sdk.webassembly.pack\10.0.9</PkgMicrosoft_NET_Sdk_WebAssembly_Pack>
    <PkgMicrosoft_NET_ILLink_Tasks Condition=" '$(PkgMicrosoft_NET_ILLink_Tasks)' == '' ">C:\Users\llocl\.nuget\packages\microsoft.net.illink.tasks\10.0.9</PkgMicrosoft_NET_ILLink_Tasks>
