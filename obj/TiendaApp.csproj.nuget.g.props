    <Import Project="$(NuGetPackageRoot)microsoft.net.sdk.webassembly.pack\10.0.9\build\Microsoft.NET.Sdk.WebAssembly.Pack.props" Condition="Exists('$(NuGetPackageRoot)microsoft.net.sdk.webassembly.pack\10.0.9\build\Microsoft.NET.Sdk.WebAssembly.Pack.props')" />
